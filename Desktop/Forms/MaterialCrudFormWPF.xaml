<Window x:Class="MaterialCrudFormWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Materials &amp; Blocks"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        Background="#1F2125"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#1F2125">
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2B2E34" BorderBrush="#111" BorderThickness="0,0,0,1">
            <Grid Margin="12,0,8,0">
                <TextBlock Text="Materials &amp; Blocks" Foreground="#D9E0EE" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#25272C" BorderBrush="#111" BorderThickness="0,0,0,1">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" Height="26" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" Padding="8,3" TextChanged="OnSearchChanged" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="DeleteButton" Content="Delete" Width="74" Height="26" Margin="0,0,6,0" Click="OnDeleteClick" />
                    <Button x:Name="NewMaterialButton" Content="+ Material" Width="84" Height="26" Margin="0,0,6,0" Click="OnNewMaterialClick" />
                    <Button x:Name="NewBlockButton" Content="+ Block" Width="74" Height="26" Click="OnNewBlockClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Background="#25272C" BorderBrush="#111" BorderThickness="0,0,1,0" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Library" Foreground="#D9E0EE" FontWeight="Bold" Margin="0,0,0,8" />
                <TreeView x:Name="LibraryTree" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" SelectedItemChanged="OnTreeSelectionChanged" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="AddMaterialButton" Content="+ Material" Width="88" Height="26" Margin="0,0,6,0" Click="OnNewMaterialClick" />
                    <Button x:Name="AddBlockButton" Content="+ Block" Width="74" Height="26" Click="OnNewBlockClick" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Grid.Column="1" Background="#1F2125" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <TextBlock Text="Concrete Column" Foreground="#D9E0EE" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Block · Dimension Mode D3 (Volume) · 4 nested components" Foreground="#AAB2BD" Margin="0,4,0,16" />

                <Border Background="#25272C" BorderBrush="#111" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Block Definition" Foreground="#D9E0EE" FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Kind" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <TextBox x:Name="KindBox" Grid.Row="1" Grid.Column="1" Margin="0,0,12,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Code" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <TextBox x:Name="CodeBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Display Name" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <TextBox x:Name="NameBox" Grid.Row="2" Grid.Column="1" Margin="0,0,12,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Dim Mode" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <ComboBox x:Name="ModeBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45">
                            <ComboBoxItem Content="D0 — Count" />
                            <ComboBoxItem Content="D1 — Length" />
                            <ComboBoxItem Content="D2 — Area" />
                            <ComboBoxItem Content="D3 — Volume" IsSelected="True" />
                        </ComboBox>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Unit" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <TextBox x:Name="UnitBox" Grid.Row="3" Grid.Column="1" Margin="0,0,12,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Density" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <ComboBox x:Name="DensityBox" Grid.Row="3" Grid.Column="3" Margin="0,0,0,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45">
                            <ComboBoxItem Content="N/A" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Heavy" IsSelected="True" />
                        </ComboBox>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit Price" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <TextBox x:Name="PriceBox" Grid.Row="4" Grid.Column="1" Margin="0,0,12,8" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Description" Foreground="#AAB2BD" VerticalAlignment="Top" Margin="0,8,0,0" />
                        <TextBox x:Name="DescriptionBox" Grid.Row="4" Grid.Column="3" Margin="0,8,0,0" Height="72" AcceptsReturn="True" TextWrapping="Wrap" Background="#1F2125" Foreground="#D9E0EE" BorderBrush="#3A3E45" />
                    </Grid>
                </Border>

                <Border Background="#25272C" BorderBrush="#111" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Composition" Foreground="#D9E0EE" FontWeight="Bold" Margin="0,0,0,10" />
                        <DataGrid x:Name="ComponentsGrid" Height="260" AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="False" CanUserAddRows="False" Background="#1F2125" Foreground="#D9E0EE" GridLinesVisibility="Horizontal" BorderBrush="#3A3E45">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Qty / m3" Binding="{Binding Quantity}" Width="90" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80" />
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="100" />
                                <DataGridTextColumn Header="Line Cost" Binding="{Binding LineCost}" Width="100" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button x:Name="AddRowButton" Content="+ Add Component" Width="132" Height="28" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnAddRowClick" />
                    </StackPanel>
                </Border>

                <Border Background="#25272C" BorderBrush="#111" BorderThickness="1" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DirtyText" Text="Saved" Foreground="#AAB2BD" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="RevertButton" Content="Revert" Width="72" Height="28" Margin="0,0,8,0" Click="OnRevertClick" />
                            <Button x:Name="SaveButton" Content="Save Block" Width="92" Height="28" Background="#E07B39" Foreground="White" Click="OnSaveClick" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
