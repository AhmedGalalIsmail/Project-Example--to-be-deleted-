<Window x:Class="MainWPFform"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CoNSoL-TakeOff"
        Width="1520"
        Height="940"
        MinWidth="1280"
        MinHeight="820"
        Background="#1F2125"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1F2125">
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="26" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2B2E34" BorderBrush="#111" BorderThickness="0,0,0,1">
            <Grid Margin="12,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="18" Background="#E07B39" CornerRadius="2" Margin="0,0,10,0">
                        <TextBlock Text="CoNSoL" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="CoNSoL-TakeOff" Foreground="#D9E0EE" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton" Content="_" Width="42" Height="30" Margin="0,0,2,0" Background="#2B2E34" Foreground="#C8CDD6" BorderThickness="0" Click="OnMinimizeClick" />
                    <Button x:Name="MaximizeButton" Content="[]" Width="42" Height="30" Margin="0,0,2,0" Background="#2B2E34" Foreground="#C8CDD6" BorderThickness="0" Click="OnMaximizeClick" />
                    <Button x:Name="CloseButton" Content="X" Width="42" Height="30" Background="#2B2E34" Foreground="#C8CDD6" BorderThickness="0" Click="OnCloseClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Menu Grid.Row="1" Background="#25272C" Foreground="#D9E0EE" BorderBrush="#111" BorderThickness="0,0,0,1">
            <MenuItem Header="File">
                <MenuItem Header="New" Click="OnNewClick" />
                <MenuItem Header="Open" Click="OnOpenClick" />
                <MenuItem Header="Save" Click="OnSaveClick" />
                <Separator />
                <MenuItem Header="Exit" Click="OnCloseClick" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Materials &amp; Blocks" Click="OnOpenCrudClick" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Grid" Click="OnGridClick" />
                <MenuItem Header="Zoom In" Click="OnZoomInClick" />
                <MenuItem Header="Zoom Out" Click="OnZoomOutClick" />
            </MenuItem>
            <MenuItem Header="Tools">
                <MenuItem Header="Select" Click="OnToolClick" Tag="Select" />
                <MenuItem Header="Line" Click="OnToolClick" Tag="Line" />
                <MenuItem Header="Rectangle" Click="OnToolClick" Tag="Rectangle" />
                <MenuItem Header="Ellipse" Click="OnToolClick" Tag="Ellipse" />
                <MenuItem Header="Polyline" Click="OnToolClick" Tag="Polyline" />
                <MenuItem Header="Pan" Click="OnToolClick" Tag="Pan" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="2" Background="#2B2E34" BorderBrush="#111" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Button x:Name="NewButton" Content="New" Width="58" Margin="0,0,6,0" Click="OnNewClick" />
                <Button x:Name="OpenButton" Content="Open" Width="58" Margin="0,0,6,0" Click="OnOpenClick" />
                <Button x:Name="SaveButton" Content="Save" Width="58" Margin="0,0,10,0" Click="OnSaveClick" />
                <Button x:Name="ImportButton" Content="Import" Width="64" Margin="0,0,6,0" Click="OnImportClick" />
                <Button x:Name="ExportButton" Content="Export" Width="64" Margin="0,0,6,0" Click="OnExportClick" />
                <Button x:Name="CrudButton" Content="Materials" Width="76" Margin="0,0,10,0" Click="OnOpenCrudClick" />
                <Button x:Name="SelectToolButton" Content="Select" Width="64" Margin="0,0,6,0" Tag="Select" Click="OnToolClick" />
                <Button x:Name="LineToolButton" Content="Line" Width="58" Margin="0,0,6,0" Tag="Line" Click="OnToolClick" />
                <Button x:Name="RectToolButton" Content="Rect" Width="58" Margin="0,0,6,0" Tag="Rectangle" Click="OnToolClick" />
                <Button x:Name="EllipseToolButton" Content="Ellipse" Width="66" Margin="0,0,6,0" Tag="Ellipse" Click="OnToolClick" />
                <Button x:Name="PolyToolButton" Content="Poly" Width="58" Margin="0,0,6,0" Tag="Polyline" Click="OnToolClick" />
                <Button x:Name="PanToolButton" Content="Pan" Width="58" Margin="0,0,10,0" Tag="Pan" Click="OnToolClick" />
                <Button x:Name="GridButton" Content="Grid" Width="58" Margin="0,0,6,0" Click="OnGridClick" />
                <Button x:Name="ZoomInButton" Content="Zoom+" Width="64" Margin="0,0,6,0" Click="OnZoomInClick" />
                <Button x:Name="ZoomOutButton" Content="Zoom-" Width="64" Click="OnZoomOutClick" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="46" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#25272C" BorderBrush="#111" BorderThickness="0,0,1,0" Padding="6,8">
                <StackPanel>
                    <Button Content="S" Height="32" Margin="0,0,0,6" Tag="Select" Click="OnToolClick" />
                    <Button Content="L" Height="32" Margin="0,0,0,6" Tag="Line" Click="OnToolClick" />
                    <Button Content="R" Height="32" Margin="0,0,0,6" Tag="Rectangle" Click="OnToolClick" />
                    <Button Content="O" Height="32" Margin="0,0,0,6" Tag="Ellipse" Click="OnToolClick" />
                    <Button Content="P" Height="32" Margin="0,0,0,6" Tag="Polyline" Click="OnToolClick" />
                    <Button Content=">" Height="32" Tag="Pan" Click="OnToolClick" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#F8F9FB" BorderBrush="#D4D7DD" BorderThickness="0,0,1,0" Padding="18">
                <Grid x:Name="CanvasHost" MouseMove="OnCanvasMouseMove">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="1" Background="#EFF2F6" BorderBrush="#D4D7DD" BorderThickness="1,1,1,0">
                        <Canvas IsHitTestVisible="False">
                            <Line X1="0" Y1="23" X2="2000" Y2="23" Stroke="#B7BFC9" StrokeThickness="1" />
                            <TextBlock Text="0.0" Foreground="#4E5968" FontSize="10" Canvas.Left="0" Canvas.Top="4" />
                            <TextBlock Text="10" Foreground="#4E5968" FontSize="10" Canvas.Left="100" Canvas.Top="4" />
                            <TextBlock Text="20" Foreground="#4E5968" FontSize="10" Canvas.Left="200" Canvas.Top="4" />
                        </Canvas>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Background="#EFF2F6" BorderBrush="#D4D7DD" BorderThickness="1,0,0,1">
                        <Canvas IsHitTestVisible="False">
                            <Line X1="23" Y1="0" X2="23" Y2="2000" Stroke="#B7BFC9" StrokeThickness="1" />
                            <TextBlock Text="0.0" Foreground="#4E5968" FontSize="10" Canvas.Left="2" Canvas.Top="0" />
                            <TextBlock Text="10" Foreground="#4E5968" FontSize="10" Canvas.Left="2" Canvas.Top="100" />
                            <TextBlock Text="20" Foreground="#4E5968" FontSize="10" Canvas.Left="2" Canvas.Top="200" />
                        </Canvas>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" x:Name="CanvasSurface" Background="#FFFFFF" BorderBrush="#E2E5EA" BorderThickness="1">
                        <Grid x:Name="CanvasGridLayer">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Grid.Background>
                                <DrawingBrush x:Name="CanvasGridBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute" Stretch="None">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="#FFFFFF">
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#ECEFF3" Thickness="1" />
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,20,20" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Grid.Background>

                            <Grid>
                                <Rectangle Height="1.5" Fill="#E07B39" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                <Rectangle Width="1.5" Fill="#E07B39" HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                                <Ellipse Width="8" Height="8" Fill="#E07B39" Stroke="#FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="0.0" Foreground="#E07B39" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,8,0,0" />
                                <Rectangle Margin="180,90,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="280" Height="18" Fill="#555" Stroke="#333" StrokeThickness="2" />
                                <Rectangle Margin="180,170,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="180" Fill="#7F8C8D" Stroke="#2B2E34" StrokeThickness="2" />
                            </Grid>

                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,32,20,0" Width="190" Padding="10" Background="#25272C" BorderBrush="#111" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Canvas" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,0,0,4" />
                                    <TextBlock Text="Origin at 0.0 intercept" Foreground="#D9E0EE" FontSize="11" />
                                    <TextBlock Text="Axes stay fixed while editing" Foreground="#D9E0EE" FontSize="11" />
                                    <TextBlock Text="Grid and zoom follow the shell" Foreground="#D9E0EE" FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#25272C" Padding="0">
                <TabControl Background="#25272C" BorderBrush="#111" Foreground="#D9E0EE">
                    <TabItem Header="Properties">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <TextBlock Text="Object" FontWeight="Bold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Type" Foreground="#AAB2BD" /><TextBlock Text="Rectangle" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="ID" Foreground="#AAB2BD" /><TextBlock Text="a3f9...d2" FontSize="11" Foreground="#9097A3" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Layer" Foreground="#AAB2BD" /><ComboBox Width="180"><ComboBoxItem Content="Walls" IsSelected="True" /><ComboBoxItem Content="Slabs" /><ComboBoxItem Content="Doors" /></ComboBox></StackPanel>
                                <Separator Margin="0,10" />
                                <TextBlock Text="Geometry" FontWeight="Bold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="X" Foreground="#AAB2BD" /><TextBlock Text="2.25 m" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Y" Foreground="#AAB2BD" /><TextBlock Text="6.05 m" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Width" Foreground="#AAB2BD" /><TextBlock Text="1.50 m" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Height" Foreground="#AAB2BD" /><TextBlock Text="0.45 m" /></StackPanel>
                                <Separator Margin="0,10" />
                                <TextBlock Text="Business" FontWeight="Bold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Block" Foreground="#AAB2BD" /><TextBlock Text="DOOR-01" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Dim Mode" Foreground="#AAB2BD" /><TextBlock Text="D0 ? Count" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Qty" Foreground="#AAB2BD" /><TextBlock Text="1" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><TextBlock Width="90" Text="Unit Price" Foreground="#AAB2BD" /><TextBlock Text="450.00" /></StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Tags">
                        <TextBlock Text="Tags view" Foreground="#AAB2BD" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </TabItem>
                    <TabItem Header="Marks">
                        <TextBlock Text="Marks view" Foreground="#AAB2BD" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="#1F2125" BorderBrush="#111" BorderThickness="0,1,0,0" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="#25272C">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Layers" Foreground="#D9E0EE" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0" />
                    <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="LayerAddButton" Content="+" Width="28" Height="22" Margin="0,0,4,0" Click="OnLayerAddClick" />
                        <Button x:Name="LayerDeleteButton" Content="-" Width="28" Height="22" Margin="0,0,4,0" Click="OnLayerDeleteClick" />
                        <Button x:Name="LayerSettingsButton" Content="?" Width="28" Height="22" Click="OnLayerSettingsClick" />
                    </StackPanel>
                </Grid>
                <DataGrid Grid.Row="1" x:Name="LayerGrid" Margin="0,8,0,0" AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True" Background="#25272C" Foreground="#D9E0EE" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Color" Binding="{Binding ColorTag}" Width="60" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Obj" Binding="{Binding ObjectCount}" Width="60" />
                        <DataGridCheckBoxColumn Header="Vis" Binding="{Binding Visible}" Width="50" />
                        <DataGridCheckBoxColumn Header="Lock" Binding="{Binding Locked}" Width="60" />
                        <DataGridCheckBoxColumn Header="Print" Binding="{Binding Printable}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StatusBar Grid.Row="5" Background="#25272C" Foreground="#D9E0EE">
            <StatusBarItem><TextBlock x:Name="StatusMessageText" Text="Ready" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusSelectionText" Text="Selection: none" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusLayerText" Text="Layer: Walls" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusToolText" Text="Tool: Select" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusCoordsText" Text="Cursor: --, --" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusZoomText" Text="Zoom: 100%" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusGridText" Text="Grid: On | Snap: On" /></StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
